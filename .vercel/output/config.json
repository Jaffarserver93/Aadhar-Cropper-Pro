{
  "version": 3,
  "routes": [
    {
      "src": "^/api/removebg$",
      "dest": "/api/removebg"
    },
    {
      "src": "^/assets/(.+)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "^/((?!api/).*)$",
      "dest": "/index.html"
    }
  ]
}