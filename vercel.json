{
  "buildCommand": "pnpm --filter @workspace/print-sahyogi run build",
  "outputDirectory": "artifacts/print-sahyogi/build",
  "framework": null,
  "rewrites": [
    { "source": "/api/removebg", "destination": "/api/removebg" },
    { "source": "/api/enhance",  "destination": "/api/enhance"  },
    { "source": "/(.*)",         "destination": "/index.html"   }
  ]
}
