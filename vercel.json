{
  "buildCommand": "pnpm --filter @workspace/print-sahyogi run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/print-sahyogi/build",
  "functions": {
    "api/removebg.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
